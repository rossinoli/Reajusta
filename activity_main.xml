<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center"
        android:background="#FDFBFF"
        tools:context=".MainActivity">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Reajusta"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@android:color/holo_blue_dark"
            android:layout_marginBottom="30dp" />

        <EditText
            android:id="@+id/editSalario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Digite o salário atual (R$)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="15dp" />

        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calcular Reajuste"
            android:onClick="calcularReajuste"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/txtSalarioAntes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salário antes: R$ 0,00"
            android:textSize="16sp"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/txtPercentual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Percentual aplicado: 0%"
            android:textSize="16sp"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/txtValorAumento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Valor do aumento: R$ 0,00"
            android:textSize="16sp"
            android:layout_marginBottom="5dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/txtNovoSalario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Novo salário: R$ 0,00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@android:color/holo_green_dark" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>